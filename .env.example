# Copy this file to .env and fill in whichever provider keys you want to use.
# Bun auto-loads .env from cwd; these populate process.env at runtime.
# .env itself is gitignored — keys never leave your machine.

# Optional: path to your Web Clipper settings JSON (file or folder).
# When set, `wch <url> -t <name>` works without --settings.
# WEB_CLIPPER_SETTINGS_PATH=/path/to/obsidian-web-clipper-settings.json

# Anthropic native (/v1/messages)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (OpenAI-compatible endpoint at generativelanguage.googleapis.com/v1beta)
# GEMINI_API_KEY=...

# OpenAI native
# OPENAI_API_KEY=sk-...

# OpenRouter (one key, many models)
# OPENROUTER_API_KEY=sk-or-...

# Other supported: DEEPSEEK_API_KEY, GROQ_API_KEY, MISTRAL_API_KEY,
# PERPLEXITY_API_KEY, XAI_API_KEY, COHERE_API_KEY, HF_TOKEN,
# AZURE_OPENAI_API_KEY (with AZURE_OPENAI_ENDPOINT)
